{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(nix develop --command go build ./... 2>&1 && nix develop --command go test ./... 2>&1)",
      "Bash(nix develop --command go build ./...)",
      "Bash(nix develop --command go test ./...)"
    ],
    "deny": ["Read(./.env)", "Read(./.env.*)"]
  }
}
