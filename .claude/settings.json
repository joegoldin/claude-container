{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(go test *)",
      "Bash(go build *)",
      "Bash(go vet *)",
      "Bash(go fmt *)",
      "Bash(go doc *)",
      "Bash(go version)",
      "Bash(nix develop --command go test *)",
      "Bash(nix develop --command go build *)",
      "Bash(nix develop --command go vet *)",
      "Bash(nix develop --command go fmt *)",
      "Bash(nix develop -c go test *)",
      "Bash(nix develop -c go build *)",
      "Bash(nix develop -c go vet *)",
      "Bash(nix develop -c go fmt *)",
      "Bash(nix develop -c bash -c 'go test*)",
      "Bash(nix develop -c bash -c 'go build*)",
      "Bash(nix develop -c bash -c 'go vet*)",
      "Bash(nix build)",
      "Bash(nix build .)",
      "Bash(nix build .#*)",
      "Bash(nix flake metadata)",
      "Bash(nix flake check)",
      "Bash(git rev-parse *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git log)",
      "Bash(git log *)",
      "Bash(git show)",
      "Bash(git show *)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git branch)",
      "Bash(git branch --list*)",
      "Bash(git worktree list*)",
      "Bash(git ls-files *)",
      "Bash(git ls-files)"
    ],
    "deny": ["Read(./.env)", "Read(./.env.*)"]
  }
}
