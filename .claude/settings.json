{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Edit(./**)",
      "Write(./**)",
      "Edit(/tmp/**)",
      "Write(/tmp/**)",
      "Grep",
      "Glob",
      "TodoWrite",
      "TaskCreate",
      "TaskGet",
      "TaskList",
      "TaskOutput",
      "TaskStop",
      "TaskUpdate",
      "Bash(go *)",
      "Bash(devenv shell -- *)",
      "Bash(devenv shell *)",
      "Bash(devenv test *)",
      "Bash(devenv test)",
      "Bash(devenv info)",
      "Bash(devenv info *)",
      "Bash(nix build)",
      "Bash(nix build .)",
      "Bash(nix build .#*)",
      "Bash(nix flake metadata)",
      "Bash(nix flake check)",
      "Bash(git rev-parse *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git log)",
      "Bash(git log *)",
      "Bash(git show)",
      "Bash(git show *)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git branch)",
      "Bash(git branch --list*)",
      "Bash(git worktree list*)",
      "Bash(git ls-files *)",
      "Bash(git ls-files)",
      "Bash(git stash *)",
      "Bash(git checkout *)",
      "Bash(ls *)",
      "Bash(ls)",
      "Bash(find *)",
      "Bash(rm *)",
      "Bash(rg *)",
      "Bash(grep *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(tree *)",
      "Bash(pwd)",
      "Bash(echo *)",
      "Bash(mkdir *)",
      "Bash(touch *)",
      "Bash(mv *)",
      "Bash(cp *)",
      "Bash(jq *)",
      "Bash(true)",
      "Bash(false)",
      "Bash(/tmp/*)",
      "Bash(/tmp/* *)",
      "Bash(docker version)",
      "Bash(docker version *)",
      "Bash(docker info)",
      "Bash(docker info *)",
      "Bash(docker ps)",
      "Bash(docker ps *)",
      "Bash(docker images)",
      "Bash(docker images *)",
      "Bash(docker inspect *)",
      "Bash(docker logs *)",
      "Bash(docker stats)",
      "Bash(docker stats *)",
      "Bash(docker port *)",
      "Bash(docker top *)",
      "Bash(docker history *)",
      "Bash(docker events *)",
      "Bash(docker network ls)",
      "Bash(docker network ls *)",
      "Bash(docker network inspect *)",
      "Bash(docker volume ls)",
      "Bash(docker volume ls *)",
      "Bash(docker volume inspect *)",
      "Bash(docker container ls *)",
      "Bash(docker image ls *)",
      "Bash(docker system df *)",
      "Bash(docker system info *)",
      "Bash(docker * ls)",
      "Bash(docker * ls *)",
      "Bash(docker * inspect *)",
      "Bash(docker start *)",
      "Bash(docker stop *)",
      "Bash(docker restart *)",
      "Bash(docker kill *)",
      "Bash(docker rm *)",
      "Bash(docker pause *)",
      "Bash(docker unpause *)",
      "Bash(docker wait *)",
      "Bash(docker run claude-container*)",
      "Bash(docker run --rm claude-container*)",
      "Bash(docker run -it claude-container*)",
      "Bash(docker run -d claude-container*)",
      "Bash(docker run --rm -it claude-container*)",
      "Bash(docker run -it --rm claude-container*)",
      "Bash(docker run --rm -d claude-container*)",
      "Bash(docker run -d --rm claude-container*)",
      "Bash(docker run claude-proxy*)",
      "Bash(docker run --rm claude-proxy*)",
      "Bash(docker run -it claude-proxy*)",
      "Bash(docker run -d claude-proxy*)",
      "Bash(docker run --rm -it claude-proxy*)",
      "Bash(docker run -it --rm claude-proxy*)",
      "Bash(docker run --rm -d claude-proxy*)",
      "Bash(docker run -d --rm claude-proxy*)",
      "Bash(docker build -t claude-container*)",
      "Bash(docker build -t claude-proxy*)",
      "Bash(docker build --tag claude-container*)",
      "Bash(docker build --tag claude-proxy*)"
    ],
    "deny": []
  },
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "autoAllowBashIfSandboxed": false,
    "allowUnsandboxedCommands": false,
    "excludedCommands": ["docker *"],
    "network": {
      "allowAllUnixSockets": true,
      "allowManagedDomainsOnly": true,
      "allowedDomains": [
        "proxy.golang.org",
        "sum.golang.org",
        "github.com",
        "*.github.com",
        "objects.githubusercontent.com",
        "raw.githubusercontent.com",
        "cache.nixos.org",
        "*.cachix.org",
        "registry-1.docker.io",
        "auth.docker.io",
        "production.cloudflare.docker.com",
        "pypi.org",
        "*.pythonhosted.org"
      ]
    },
    "filesystem": {
      "denyWrite": ["/"],
      "allowWrite": [
        ".",
        "/proc/self/fd",
        "/dev/null",
        "/dev/stdout",
        "/dev/stderr",
        "/dev/tty",
        "/dev/dtracehelper",
        "/dev/autofs_nowait",
        "/tmp",
        "$TMPDIR",
        "~/.cache/go-build",
        "~/go/pkg",
        "~/.cache/nix",
        "~/.npm/_logs",
        "~/.claude/debug"
      ],
      "denyRead": ["/"],
      "allowRead": [
        ".",
        "/nix",
        "/etc/profiles/per-user/joe",
        "/run/current-system/sw",
        "/etc/static",
        "/etc/passwd",
        "/etc/group",
        "/etc/hosts",
        "/etc/resolv.conf",
        "/etc/ssl/certs",
        "/etc/nix",
        "/etc/gitconfig",
        "/proc/self",
        "/dev/null",
        "/dev/urandom",
        "/dev/random",
        "/dev/tty",
        "/dev/zero",
        "/tmp",
        "$TMPDIR",
        "~/.cache/go-build",
        "~/go/pkg",
        "~/.cache/nix",
        "~/.gitconfig",
        "~/.config/git"
      ]
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/docker-guard.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "autoMode": {
    "environment": [
      "$defaults",
      "Project: claude-container — a Go CLI by joegoldin (joe@joegold.in) for running multiple Claude Code instances in isolated Docker containers with per-session mitmproxy sidecars and a Bubble Tea TUI.",
      "Source control: github.com/joegoldin/claude-container — pushes here are routine; pushes to any other org or repo are not.",
      "Local Docker daemon is trusted: claude-container's whole purpose is to spawn local containers from the claude-container:* and claude-proxy:* images it builds. Reading/writing /var/run/docker.sock is expected for this project.",
      "Trusted local images: claude-container:* and claude-proxy:* are built locally via nix and the project's Dockerfile. They are NOT pulled from any registry.",
      "Build infrastructure: nix substituters cache.nixos.org and *.cachix.org are trusted. devenv reads/writes ./.devenv and ~/.cache/nix.",
      "Go module fetches via proxy.golang.org and sum.golang.org are trusted for go build/test."
    ],
    "soft_deny": [
      "$defaults",
      "Never pull container images from any registry. Only run claude-container:* and claude-proxy:* images built locally.",
      "Never run git push under any circumstances. The user pushes manually; if asked to push, decline and tell the user to do it themselves.",
      "Never modify ~/.ssh, ~/.aws, ~/.gnupg, ~/.config/gh, ~/.docker, ~/.kube, or any credentials directory."
    ]
  }
}
