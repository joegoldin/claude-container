{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(go test *)",
      "Bash(go build *)",
      "Bash(go vet *)",
      "Bash(go fmt *)",
      "Bash(go doc *)",
      "Bash(go version)",
      "Bash(devenv shell -- go test *)",
      "Bash(devenv shell -- go build *)",
      "Bash(devenv shell -- go vet *)",
      "Bash(devenv shell -- go fmt *)",
      "Bash(devenv shell -- go doc *)",
      "Bash(devenv shell -- go version)",
      "Bash(devenv shell go test *)",
      "Bash(devenv shell go build *)",
      "Bash(devenv shell go vet *)",
      "Bash(devenv shell go fmt *)",
      "Bash(devenv test *)",
      "Bash(devenv test)",
      "Bash(devenv info)",
      "Bash(devenv info *)",
      "Bash(nix build)",
      "Bash(nix build .)",
      "Bash(nix build .#*)",
      "Bash(nix flake metadata)",
      "Bash(nix flake check)",
      "Bash(git rev-parse *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git log)",
      "Bash(git log *)",
      "Bash(git show)",
      "Bash(git show *)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git branch)",
      "Bash(git branch --list*)",
      "Bash(git worktree list*)",
      "Bash(git ls-files *)",
      "Bash(git ls-files)",
      "Bash(git stash *)",
      "Bash(git checkout *)"
    ],
    "deny": ["Read(./.env)", "Read(./.env.*)"]
  }
}
